<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_date"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_calendar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_label_date"
            app:layout_constraintBottom_toBottomOf="@id/txt_run_date"
            app:tint="#444444" />

        <TextView
            android:id="@+id/tv_label_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tanggal Lari"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_date"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txt_run_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14 April"
            android:textColor="#666666"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_label_date"
            app:layout_constraintTop_toBottomOf="@id/tv_label_date" />

        <ImageView
            android:id="@+id/iv_distance"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_distance"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_label_distance"
            app:layout_constraintBottom_toBottomOf="@id/txt_run_distance"
            app:tint="#444444" />

        <TextView
            android:id="@+id/tv_label_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:text="Jarak Lari"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_distance"
            app:layout_constraintTop_toBottomOf="@id/txt_run_date" />

        <TextView
            android:id="@+id/txt_run_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 KM"
            android:textColor="#666666"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_label_distance"
            app:layout_constraintTop_toBottomOf="@id/tv_label_distance" />

        <ImageView
            android:id="@+id/iv_duration"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_timer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_label_duration"
            app:layout_constraintBottom_toBottomOf="@id/txt_run_duration"
            app:tint="#444444" />

        <TextView
            android:id="@+id/tv_label_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:text="Durasi Lari"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/iv_duration"
            app:layout_constraintTop_toBottomOf="@id/txt_run_distance" />

        <TextView
            android:id="@+id/txt_run_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5 min"
            android:textColor="#666666"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_label_duration"
            app:layout_constraintTop_toBottomOf="@id/tv_label_duration" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="#F44336"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>